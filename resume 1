<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Student Resume</title>
    <style>
        /* Pink Gradient Background & Settings */
        body {
            margin: 0;
            padding: 40px 20px;
            font-family: 'Comic Sans MS', 'Segoe UI', sans-serif; /* A bit more casual and student-friendly */
            background: linear-gradient(-45deg, #ff9a9e, #fecfef, #feada6, #f5f7fa);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow-x: hidden;
            position: relative;
            box-sizing: border-box;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Glassmorphism Container with a softer student vibe */
        .resume-container {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 2px solid rgba(255, 255, 255, 0.5);
            padding: 35px;
            border-radius: 20px;
            box-shadow: 0 8px 32px rgba(255, 154, 158, 0.2);
            z-index: 2;
            width: 100%;
            max-width: 750px;
            color: #4a3b40;
        }

        /* Header Style */
        .header {
            text-align: center;
            border-bottom: 2px dashed #ff9a9e;
            padding-bottom: 20px;
            margin-bottom: 25px;
        }

        .header h1 {
            margin: 0 0 8px 0;
            font-size: 2.3rem;
            color: #d15b76;
        }

        .contact-info {
            font-size: 0.95rem;
            color: #705660;
        }

        .contact-info span {
            margin: 0 8px;
        }

        /* Sections */
        .section {
            margin-bottom: 25px;
        }

        .section-title {
            font-size: 1.2rem;
            color: #d15b76;
            font-weight: bold;
            border-bottom: 2px solid rgba(255, 154, 158, 0.3);
            padding-bottom: 3px;
            margin-bottom: 12px;
            text-transform: uppercase;
        }

        .item {
            margin-bottom: 15px;
        }

        .item-header {
            display: flex;
            justify-content: space-between;
            font-weight: bold;
            color: #5a454d;
        }

        .item-sub {
            font-style: italic;
            color: #8c6e7a;
            margin-bottom: 5px;
            font-size: 0.95rem;
        }

        ul {
            margin: 0;
            padding-left: 20px;
            color: #5a454d;
        }

        li {
            margin-bottom: 5px;
            line-height: 1.4;
        }

        /* Bubble Stickers for Skills */
        .skills-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            padding: 0;
            list-style: none;
        }

        .skills-list li {
            background: rgba(255, 154, 158, 0.25);
            border: 1px solid rgba(255, 154, 158, 0.4);
            padding: 6px 12px;
            border-radius: 15px;
            font-size: 0.85rem;
            font-weight: bold;
            color: #a83b54;
        }

        /* Background Floating Bubbles */
        .bubbles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        .bubble {
            position: absolute;
            bottom: -120px;
            background: rgba(255, 255, 255, 0.45);
            border-radius: 50%;
            animation: floatUp 12s infinite ease-in;
        }

        .bubble:nth-child(1) { left: 5%; width: 45px; height: 45px; animation-delay: 0s; animation-duration: 9s; }
        .bubble:nth-child(2) { left: 25%; width: 25px; height: 25px; animation-delay: 3s; animation-duration: 11s; }
        .bubble:nth-child(3) { left: 50%; width: 60px; height: 60px; animation-delay: 1s; animation-duration: 10s; }
        .bubble:nth-child(4) { left: 75%; width: 35px; height: 35px; animation-delay: 6s; animation-duration: 8s; }
        .bubble:nth-child(5) { left: 90%; width: 70px; height: 70px; animation-delay: 2s; animation-duration: 14s; }

        @keyframes floatUp {
            0% {
                transform: translateY(0) scale(1);
                opacity: 0;
            }
            15% { opacity: 0.7; }
            85% { opacity: 0.7; }
            100% {
                transform: translateY(-120vh) scale(1.3);
                opacity: 0;
            }
        }
    </style>
</head>
